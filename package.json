{
  "name": "opencode-sync-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for syncing opencode workspace configuration across devices",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencode-sync": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "rimraf": "^5.0.0"
  }
}
